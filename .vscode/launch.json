{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CP: Watch Mode (auto-run on save)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/watch_cp.py",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "CP: Fast Run (inputs.txt -> output.txt)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_judge.py",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen",
      "justMyCode": true
    }
  ]
}
